{
  "name": "calculator-app",
  "version": "1.1.0",
  "description": "Simple Calculator Desktop App built with Electron",
  "main": "main.js",
  "type": "commonjs",
  "author": "",
  "license": "ISC",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },

  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },

  "build": {
    "appId": "com.calculator.app",
    "productName": "Calculator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "app/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "app/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}